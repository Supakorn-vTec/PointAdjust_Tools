<Window x:Class="vtecPoint.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="vtecPoint — ปรับแต้มสมาชิก"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid x:Name="LoadingPanel" Background="#F5F5F5">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="vtecPoint" FontSize="28" FontWeight="SemiBold"
                           Foreground="#5B5FC7" HorizontalAlignment="Center" />
                <TextBlock Text="กำลังเริ่มระบบ..." FontSize="14" Foreground="#616161"
                           Margin="0,12,0,0" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
        <wv2:WebView2 x:Name="WebView" Visibility="Collapsed" />
    </Grid>
</Window>
